<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_gradient">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:titleTextColor="@color/text_primary" />
    </com.google.android.material.appbar.AppBarLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/screen_horizontal">

            <!-- Payout Method Toggle -->
            <com.google.android.material.button.MaterialButtonToggleGroup
                android:id="@+id/togglePayoutMethod"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_lg"
                app:singleSelection="true"
                app:checkedButton="@id/btnMobileMoney">

                <Button
                    android:id="@+id/btnMobileMoney"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Mobile Money" />

                <Button
                    android:id="@+id/btnBankTransfer"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="Bank Transfer" />
            </com.google.android.material.button.MaterialButtonToggleGroup>

            <!-- Currency Chips -->
            <TextView
                style="@style/TextAppearance.Label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Payout Currency"
                android:layout_marginTop="@dimen/spacing_md" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupCurrency"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                app:singleSelection="true" />

            <!-- Network Picker (mobile money only) -->
            <LinearLayout
                android:id="@+id/layoutNetworkPicker"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="@dimen/spacing_md">

                <TextView
                    style="@style/TextAppearance.Label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Network" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chipGroupNetwork"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/spacing_sm"
                    app:singleSelection="true" />
            </LinearLayout>

            <!-- Mobile Money Fields -->
            <LinearLayout
                android:id="@+id/layoutMobileMoney"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="@dimen/spacing_md">

                <TextView
                    style="@style/TextAppearance.Label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Phone Number" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/input_height"
                    android:layout_marginTop="@dimen/spacing_sm"
                    android:orientation="horizontal"
                    android:background="@color/input_background"
                    android:gravity="center_vertical">

                    <TextView
                        android:id="@+id/tvCountryCode"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:paddingHorizontal="@dimen/spacing_md"
                        android:text="+256"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body_large" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="24dp"
                        android:background="@color/border_default" />

                    <EditText
                        android:id="@+id/editTextPhone"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:paddingStart="@dimen/spacing_sm"
                        android:paddingEnd="@dimen/spacing_md"
                        android:background="@android:color/transparent"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body_large"
                        android:inputType="phone"
                        android:hint="700000001"
                        android:textColorHint="@color/text_placeholder" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvPhoneHelper"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Enter phone number"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="@dimen/spacing_xs" />
            </LinearLayout>

            <!-- Bank Transfer Fields -->
            <LinearLayout
                android:id="@+id/layoutBankTransfer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="@dimen/spacing_md"
                android:visibility="gone">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.App.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Bank Code"
                    android:layout_marginBottom="@dimen/spacing_md">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editTextBankCode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.App.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Account Number"
                    android:layout_marginBottom="@dimen/spacing_md">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editTextAccountNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="number" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.App.TextInputLayout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Account Name">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editTextAccountName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <!-- Amount Input -->
            <TextView
                android:id="@+id/tvAmountLabel"
                style="@style/TextAppearance.Label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Amount (UGX)"
                android:layout_marginTop="@dimen/spacing_md" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.App.TextInputLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editTextAmount"
                    style="@style/Widget.App.TextInputEditText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Enter amount"
                    android:inputType="numberDecimal" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Fee Display Section -->
            <LinearLayout
                android:id="@+id/feeSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/spacing_md"
                android:background="@color/input_background"
                android:layout_marginTop="@dimen/spacing_md"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/spacing_sm">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Amount"
                        style="@style/TextAppearance.BodyRegular"
                        android:textColor="@color/text_secondary" />
                    <TextView
                        android:id="@+id/tvWithdrawAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/TextAppearance.BodyRegular"
                        android:textColor="@color/text_primary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/spacing_sm">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Transaction fee"
                        style="@style/TextAppearance.BodyRegular"
                        android:textColor="@color/text_secondary" />
                    <TextView
                        android:id="@+id/tvTransactionFeeAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/TextAppearance.BodyRegular"
                        android:textColor="@color/text_primary" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/spacing_sm">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Total Debited"
                        style="@style/TextAppearance.BodyLarge"
                        android:textColor="@color/text_primary" />
                    <TextView
                        android:id="@+id/tvTotalAmount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/TextAppearance.BodyLarge"
                        android:textColor="@color/primary_gold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="@dimen/spacing_xs">
                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Balance After"
                        style="@style/TextAppearance.BodyRegular"
                        android:textColor="@color/text_secondary" />
                    <TextView
                        android:id="@+id/tvBalanceAfter"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        style="@style/TextAppearance.BodyRegular"
                        android:textColor="@color/success_green" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvFeeNote"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="* Estimated — confirmed on submit"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Error Message -->
            <TextView
                android:id="@+id/textError"
                style="@style/TextAppearance.BodyRegular"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_md"
                android:textColor="@color/error_red"
                android:visibility="gone" />

            <!-- Info Text -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="@dimen/spacing_md"
                android:background="@color/input_background"
                android:layout_marginTop="@dimen/spacing_md">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_info"
                    android:contentDescription="Info"
                    app:tint="@color/text_secondary" />

                <TextView
                    android:id="@+id/tvWithdrawInfo"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="@dimen/spacing_sm"
                    android:text="Funds will be sent within 5 minutes"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <!-- Progress Bar -->
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="@dimen/spacing_md"
                android:visibility="gone" />

            <!-- Withdraw Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWithdraw"
                style="@style/Widget.App.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height"
                android:text="Withdraw"
                android:enabled="false"
                android:layout_marginTop="@dimen/spacing_md"
                android:layout_marginBottom="@dimen/spacing_lg" />
        </LinearLayout>
    </ScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout>